# Porta HTTP do backend
PORT=4000

# Caminho do arquivo SQLite (persistido em volume Docker)
DATABASE_PATH=./data/orquestrador.sqlite

# Nível de log: trace | debug | info | warn | error
LOG_LEVEL=info

# Origem permitida para CORS (frontend). Use * para liberar geral em dev.
CORS_ORIGIN=*

# TTL (ms) do cache de estatísticas agregadas
STATS_CACHE_TTL_MS=5000

# Base path onde o Bull Board é montado
BULL_BOARD_BASE_PATH=/admin/queues
