# Porta HTTP do backend
PORT=4000

# Caminho do arquivo SQLite (persistido em volume Docker)
DATABASE_PATH=./data/orquestrador.sqlite

# Nível de log: trace | debug | info | warn | error
LOG_LEVEL=info

# Origem permitida para CORS (frontend). Use * para liberar geral em dev.
CORS_ORIGIN=*

# TTL (ms) do cache de estatísticas agregadas
STATS_CACHE_TTL_MS=5000

# Base path onde o Bull Board é montado
BULL_BOARD_BASE_PATH=/admin/queues

# ===== Autenticação / sessão =====
# Segredo para assinar o JWT da sessão (OBRIGATÓRIO em produção). Se vazio, um
# segredo efêmero é gerado e as sessões caem a cada restart.
JWT_SECRET=
# Senha inicial do usuário "admin" (auth local). Ele pode trocá-la na ferramenta.
ADMIN_INITIAL_PASSWORD=admin
# Duração da sessão em segundos (default 8h).
SESSION_TTL=28800
# Marque true quando servir por HTTPS (cookie Secure).
COOKIE_SECURE=false

# A configuração do Active Directory é feita pela tela "AD" na aplicação (admin)
# e fica salva no banco — não há variáveis AD_* aqui.
