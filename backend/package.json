{
  "name": "orquestrador-fila-backend",
  "version": "1.0.0",
  "description": "Plataforma de gerenciamento de filas BullMQ distribuídas em múltiplos Redis",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && node scripts/copyMigrations.mjs",
    "start": "node dist/index.js",
    "migrate": "tsx src/database/migrate.ts"
  },
  "dependencies": {
    "@bull-board/api": "^6.5.3",
    "@bull-board/express": "^6.5.3",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.7.0",
    "bullmq": "^5.34.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "ioredis": "5.10.1",
    "jsonwebtoken": "^9.0.3",
    "ldapts": "^8.1.8",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
